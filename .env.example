# =============================================
# ระบบเว็บแจ้งซ่อม - Environment Variables
# =============================================
# ให้ copy ไฟล์นี้ไปเป็น .env แล้วแก้ค่าตามสภาพแวดล้อมจริง
# cp .env.example .env

# ===== Database =====
DB_HOST=localhost
DB_USER=repair_app
DB_PASS=your_db_password_here
DB_NAME=repair_system

# ===== JWT (ห้ามใช้ค่า default — เปลี่ยนเป็นค่าสุ่มที่แข็งแรง) =====
JWT_SECRET=your_random_secure_jwt_secret_here_64chars_min
JWT_EXPIRES_IN=8h

# ===== Server =====
PORT=3000
APP_URL=http://localhost:3000
SYSTEM_URL=http://localhost:3000

# ===== Backup =====
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
# MYSQLDUMP_PATH=C:\xampp\mysql\bin\mysqldump.exe  (สำหรับ Windows+XAMPP)

# ===== Email (SMTP) =====
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your_email@gmail.com
SMTP_FROM_NAME=ระบบแจ้งซ่อมครุภัณฑ์

# ===== LINE Messaging API (LINE Official Account) =====
LINE_MESSAGING_ENABLED=true
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ===== LINE Notify (เลิกใช้แล้ว — LINE Notify ปิดบริการตั้งแต่ 1 เม.ย. 2025) =====
LINE_NOTIFY_ENABLED=false
LINE_NOTIFY_TOKEN=

# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token